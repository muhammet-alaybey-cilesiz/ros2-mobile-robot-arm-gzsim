<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    

    <xacro:property name="arm_base_link_length" value="0.1" />
    <xacro:property name="arm_base_link_width" value="0.1" />   
    <xacro:property name="arm_base_link_height" value="0.02" />
    <xacro:property name="arm_base_link_mass" value="0.5" />

    <xacro:property name="forearm_link_radius" value="0.02" />
    <xacro:property name="forearm_link_length" value="0.3" />
    <xacro:property name="forearm_link_mass" value="0.3" />

    <xacro:property name="hand_link_radius" value="0.02" />
    <xacro:property name="hand_link_length" value="0.3" />
    <xacro:property name="hand_link_mass" value="0.3" />

    <link name="arm_base_footprint" />

    <link name="arm_base_link">
        <visual>
            <geometry>
                <box size="${arm_base_link_length} ${arm_base_link_width} ${arm_base_link_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_link_height / 2.0}" rpy="0 0 0" />
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <box size="${arm_base_link_length} ${arm_base_link_width} ${arm_base_link_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_link_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="${arm_base_link_mass}" x="${arm_base_link_length}" y="${arm_base_link_width}" z="${arm_base_link_height}"
                           o_xyz="0 0 ${arm_base_link_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="forearm_link">
        <visual>
            <geometry>
                <cylinder radius="${forearm_link_radius}" length="${forearm_link_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_link_length / 2.0}" rpy="0 0 0" />
            <material name="yellow" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${forearm_link_radius}" length="${forearm_link_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_link_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="${forearm_link_mass}" r="${forearm_link_radius}" l="${forearm_link_length}"
                                o_xyz="0 0 ${forearm_link_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="hand_link">
        <visual>
            <geometry>
                <cylinder radius="${hand_link_radius}" length="${hand_link_length}" />
            </geometry>
            <origin xyz="0 0 ${hand_link_length / 2.0}" rpy="0 0 0" />
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${hand_link_radius}" length="${hand_link_length}" />
            </geometry>
            <origin xyz="0 0 ${hand_link_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="${hand_link_mass}" r="${hand_link_radius}" l="${hand_link_length}"
                                o_xyz="0 0 ${hand_link_length / 2.0}" o_rpy="0 0 0" />
    </link>
    
    <joint name="arm_base_joint" type="fixed">
        <parent link="arm_base_footprint" />
        <child link="arm_base_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <joint name="forearm_joint" type="revolute">
        <parent link="arm_base_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 ${arm_base_link_height / 2.0}" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="0" upper="${pi/2}" effort="100" velocity="100" />
        <dynamics damping="0.3" friction="0.3" />
    </joint>

    <joint name="hand_joint" type="revolute">
        <parent link="forearm_link" />
        <child link="hand_link" />
        <origin xyz="0 0 ${hand_link_length / 2.0 + forearm_link_length / 2.0}" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="0" upper="${pi/2}" effort="100" velocity="100" />
        <dynamics damping="0.3" friction="0.3" />
    </joint>

    <!-- ================= ROS2 CONTROL ================= -->

    <ros2_control name="arm_system" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSystem</plugin>
        </hardware>

        <!-- Forearm Joint -->
        <joint name="forearm_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <!-- Hand Joint -->
        <joint name="hand_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

    </ros2_control>

</robot>